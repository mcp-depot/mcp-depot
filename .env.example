# MCPConnect Environment Variables
# Copy this file to .env and update values for production

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=mcpconnect

# Server
PORT=3000
NODE_ENV=development

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Encryption Key (32 bytes, CHANGE THIS!)
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Admin User (created on first start if not exists)
# ADMIN_EMAIL=admin@mcpconnect.io
# ADMIN_PASSWORD=  # leave blank to auto-generate (printed to server logs)

# Demo Data (optional - only set to true for development/demos)
# SEED_DEMO_DATA=false

# Security
ALLOW_SELF_SIGNED_CERTS=false
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ALLOW_REGISTRATION=true  # set to false to disable self-registration

# Logging
LOG_LEVEL=info

# Tools Caching (optional)
# TOOLS_CACHE_ENABLED=false
# TOOLS_CACHE_TTL=300000

# MCP Connect Wrapper
# MCP_CONNECT_TIMEOUT=30000

# MCP Server (native MCP protocol)
# MCP_ENABLED=false
# MCP_TRANSPORT=http  # stdio | http (default: http)

# Secret Store (Infisical) - opt-in
# See docs/secret-store.md for setup instructions
# Cloud (free tier): https://app.infisical.com
# Self-hosted: docker-compose --profile secret-store up

# Enable Secret Store
# SECRET_STORE_ENABLED=false
# Infisical Site URL (cloud: https://app.infisical.com, self-hosted: http://localhost:8080)
SECRET_STORE_SITE_URL=https://app.infisical.com
# Infisical Client ID (from Infisical dashboard → Settings → App Connections → Machine)
SECRET_STORE_CLIENT_ID=
# Infisical Client Secret
SECRET_STORE_CLIENT_SECRET=
# Infisical Workspace ID (from Infisical URL: app.infisical.com/workspace/<id>)
SECRET_STORE_WORKSPACE_ID=
# Infisical Environment (default: dev)
SECRET_STORE_ENVIRONMENT=dev

# Infisical self-hosted only - generate with:
#   openssl rand -hex 16   # for ENCRYPTION_KEY
#   openssl rand -base64 32  # for AUTH_SECRET
# INFISICAL_ENCRYPTION_KEY=
# INFISICAL_AUTH_SECRET=
