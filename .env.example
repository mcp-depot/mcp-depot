# MCPConnect Environment Variables
# Copy this file to .env and update values for production

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=mcpconnect

# Server
PORT=3000
NODE_ENV=development

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Encryption Key (32 bytes, CHANGE THIS!)
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Security
ALLOW_SELF_SIGNED_CERTS=false
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ALLOW_REGISTRATION=true  # set to false to disable self-registration

# Logging
LOG_LEVEL=info

# Tools Caching (optional)
# TOOLS_CACHE_ENABLED=false
# TOOLS_CACHE_TTL=300000

# MCP Connect Wrapper
# MCP_CONNECT_TIMEOUT=30000

# MCP Server (native MCP protocol)
# MCP_ENABLED=false
# MCP_TRANSPORT=http  # stdio | http (default: http)

# Secret Store (Infisical) - opt-in
# Secret Store Enabled
SECRET_STORE_ENABLED=false
# Infisical Site URL (cloud: https://app.infisical.com, self-hosted: your instance URL)
SECRET_STORE_SITE_URL=https://app.infisical.com
# Infisical Client ID (from Infisical dashboard)
SECRET_STORE_CLIENT_ID=
# Infisical Client Secret
SECRET_STORE_CLIENT_SECRET=
# Infisical Workspace ID
SECRET_STORE_WORKSPACE_ID=
# Infisical Environment (default: dev)
SECRET_STORE_ENVIRONMENT=dev

# Infisical (self-hosted only - optional)
# INFISICAL_ENCRYPTION_KEY=change-infisical-encryption-key
# INFISICAL_AUTH_SECRET=change-infisical-auth-secret
