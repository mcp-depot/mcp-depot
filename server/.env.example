# MCP Depot Environment Variables
# Copy this file to .env and update values for production

# Server
PORT=3000
NODE_ENV=development
SERVE_CLIENT=true  # Set to false to disable frontend (API-only mode)

# Database
DATABASE_URL=postgresql://admin:password@localhost:5432/mcpdepot
SQLITE_PATH=./data/mcpdepot.db  # Use SQLite instead of PostgreSQL

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Encryption Key (32 bytes, CHANGE THIS!)
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Admin User (created on first start if not exists)
# ADMIN_EMAIL=admin@mcpdepot.io
# ADMIN_PASSWORD=  # leave blank to auto-generate (printed to server logs)

# Demo Data (optional - only set to true for development/demos)
# SEED_DEMO_DATA=false

# Security
ALLOW_SELF_SIGNED_CERTS=false
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ALLOW_REGISTRATION=true  # set to false to disable self-registration

# Logging
LOG_LEVEL=info  # trace | debug | info | warn | error | fatal

# Tools Caching (optional)
# TOOLS_CACHE_ENABLED=false
# TOOLS_CACHE_TTL=300000

# Rate Limiting (default for integrations without specific config)
# RATE_LIMIT_DEFAULT_RPM=60
# RATE_LIMIT_DEFAULT_RPH=1000

# MCP Server (native MCP protocol)
# MCP_ENABLED=false
# MCP_TRANSPORT=http  # stdio | http (default: http)
# API_BASE_URL=http://localhost:3000  # Public URL for MCP server

# OAuth - Google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# OAuth - GitHub
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# OAuth - Custom OIDC (Keycloak, Okta, Auth0, etc.)
# OIDC_ENABLED=false
# OIDC_ISSUER_URL=https://your-oidc-provider.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_DISPLAY_NAME=Login with SSO

# Feature Flags (comma-separated, default: all enabled)
# ENABLED_FEATURES=integrations,tools,skills,sessions,channels,users

# Secret Store (Infisical) - opt-in
# See docs/secret-store.md for detailed setup instructions
# Cloud (free tier): https://app.infisical.com
# Self-hosted: docker-compose --profile secret-store up

# Enable Secret Store
# SECRET_STORE_ENABLED=false
# Infisical Site URL
#   - Self-hosted: http://mcpdepot-infisical:8080 (Docker internal)
#   - Cloud: https://app.infisical.com
# SECRET_STORE_SITE_URL=https://app.infisical.com
# Infisical Client ID (see docs/secret-store.md for how to get this)
# SECRET_STORE_CLIENT_ID=
# Infisical Client Secret (see docs/secret-store.md for how to get this)
# SECRET_STORE_CLIENT_SECRET=
# Infisical Workspace ID - Organization ID for self-hosted (see docs/secret-store.md)
# SECRET_STORE_WORKSPACE_ID=
# Infisical Environment (e.g., dev, prod - must match environment name in Infisical)
# SECRET_STORE_ENVIRONMENT=dev

# Infisical self-hosted only - generate with:
#   openssl rand -hex 16   # for ENCRYPTION_KEY
#   openssl rand -base64 32  # for AUTH_SECRET
# INFISICAL_ENCRYPTION_KEY=
# INFISICAL_AUTH_SECRET=